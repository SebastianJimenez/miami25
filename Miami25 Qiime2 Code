Make a manifest file to upload to Qiime2:

#Copy the following script into nano and make a file: Name it “mkmanifest.py”

#!/usr/bin/env python3

import argparse
import os
import glob

def parse_args():
    parser = argparse.ArgumentParser(description="Generate QIIME2 manifest from paired-end FASTQ files.")
    parser.add_argument(
        "-i", "--input-dir", required=True,
        help="Directory containing paired-end FASTQ files with *_R1_* in the filename."
    )
    parser.add_argument(
        "-o", "--output", default="manifest.tsv",
        help="Output manifest filename (default: manifest.tsv)"
    )
    return parser.parse_args()

def main():
    args = parse_args()
    input_dir = os.path.abspath(args.input_dir)
    r1_files = sorted(glob.glob(os.path.join(input_dir, "*_R1_*")))

    if not r1_files:
        raise FileNotFoundError("No *_R1_* files found in the specified directory.")

    with open(args.output, "w") as out:
        out.write("sample-id\tforward-absolute-filepath\treverse-absolute-filepath\n")
        for r1_path in r1_files:
            r2_path = r1_path.replace("_R1_", "_R2_")
            if not os.path.exists(r2_path):
                print(f"Warning: reverse read not found for {r1_path}, skipping.")
                continue

            basename = os.path.basename(r1_path)
            sample_id = basename.split("_")[0]
            out.write(f"{sample_id}\t{r1_path}\t{r2_path}\n")

if __name__ == "__main__":
    main()


